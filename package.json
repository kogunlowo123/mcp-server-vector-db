  "author": "kogunlowo123",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.2.0",
    "@pinecone-database/pinecone": "^2.0.0",
    "chromadb": "^1.7.0",
    "@qdrant/js-client-rest": "^1.7.0",
    "weaviate-ts-client": "^2.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.54.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
