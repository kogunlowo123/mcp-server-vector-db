{
  "name": "mcp-server-vector-db",
  "version": "1.0.0",
  "description": "MCP server for vector database operations supporting Pinecone, Weaviate, Qdrant, and ChromaDB",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "vector-database",
    "pinecone",
    "weaviate",
    "qdrant",
    "chromadb",
    "embeddings"
